#!/usr/bin/env bash

# Graphics card
CARD=$(basename "$(find /sys/class/backlight/* | head -n 1)")


# Get current brightness
get_backlight() {
	if [[ "$CARD" == *"intel_"* ]]; then
		brightnessctl --device "$CARD" -m | cut -d',' -f4
	else
		printf '%.0f%%\n' "$(light -G)"
	fi
}

# Increase brightness
inc_backlight() {
	if [[ "$CARD" == *"intel_"* ]]; then
		brightnessctl --device "$CARD" set +5%
	else
		light -A 5
	fi
}

# Decrease brightness
dec_backlight() {
	if [[ "$CARD" == *"intel_"* ]]; then
		brightnessctl --device "$CARD" set 5-%
	else
		light -U 5
	fi
}

# Execute accordingly
if [[ "$1" == "--get" ]]; then
	get_backlight
elif [[ "$1" == "--up" ]]; then
	inc_backlight
elif [[ "$1" == "--down" ]]; then
	dec_backlight
else
	get_backlight
fi
